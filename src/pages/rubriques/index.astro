---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { CATEGORIES, FALLBACK, categoryOf } from '../../lib/taxonomy.js';
import { imgSrcset } from '../../lib/format.js';

const all = await getCollection('articles');
const counts = new Map();
for (const e of all) counts.set(e.data.category, (counts.get(e.data.category) || 0) + 1);
const latestByCat = new Map();
for (const e of [...all].sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())) {
  if (!latestByCat.has(e.data.category)) latestByCat.set(e.data.category, e);
}
const cats = [...CATEGORIES, FALLBACK].filter((c) => counts.get(c.slug));
---

<BaseLayout title="Rubriques" description="Explorez toutes les rubriques d'UWOS : maison, bien-être, business, tech, finance, cuisine, voyage, mode et plus.">
  <section class="wrap" style="padding-top: clamp(3rem,8vw,6rem)">
    <header class="rub-head" data-reveal>
      <span class="kicker">Naviguer</span>
      <h1>Rubriques</h1>
      <p>{all.length} articles répartis en {cats.length} univers.</p>
    </header>

    <ul class="rub-grid">
      {cats.map((c, i) => {
        const latest = latestByCat.get(c.slug);
        const img = latest ? imgSrcset(latest.data.image) : null;
        return (
          <li class="rub-card" data-reveal style={`--reveal-delay:${i * 0.05}s`}>
            <a href={`/rubrique/${c.slug}/`} data-cursor>
              <div class="rub-card__media">
                {img ? <img src={img.src} srcset={img.srcset} sizes="(max-width:700px) 90vw, 40vw" alt="" width="1200" height="800" loading="lazy" /> : <div class="rub-card__ph"></div>}
                <span class="rub-card__idx">{String(i + 1).padStart(2, '0')}</span>
              </div>
              <div class="rub-card__body">
                <h2>{c.label}</h2>
                <p>{c.tagline}</p>
                <span class="rub-card__count">{counts.get(c.slug)} articles →</span>
              </div>
            </a>
          </li>
        );
      })}
    </ul>
  </section>
</BaseLayout>

<style>
  .rub-head { margin-bottom: clamp(2rem, 4vw, 3rem); }
  .rub-head h1 { font-size: var(--step-6); margin-top: 0.4rem; }
  .rub-head p { color: var(--muted); margin-top: 0.8rem; }
  .rub-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(min(100%, 340px), 1fr)); gap: clamp(1.5rem, 3vw, 2.2rem); }
  .rub-card a { display: block; }
  .rub-card__media { position: relative; aspect-ratio: 16/10; border-radius: var(--r-lg); overflow: hidden; background: var(--surface); }
  .rub-card__media img { width: 100%; height: 100%; object-fit: cover; filter: brightness(0.6) saturate(0.9); transition: transform 0.8s var(--ease), filter 0.5s; }
  .rub-card a:hover .rub-card__media img { transform: scale(1.07); filter: brightness(0.75); }
  .rub-card__ph { position: absolute; inset: 0; background: linear-gradient(140deg, var(--surface-2), var(--ink)); }
  .rub-card__idx {
    position: absolute; top: 1rem; right: 1.2rem;
    font-family: var(--font-display); font-weight: 800; font-size: var(--step-4);
    color: color-mix(in oklab, var(--paper) 85%, transparent); -webkit-text-stroke: 1px var(--void); line-height: 1;
  }
  .rub-card__body { padding-top: 1rem; }
  .rub-card__body h2 { font-size: var(--step-2); transition: color 0.3s; }
  .rub-card a:hover h2 { color: var(--orange); }
  .rub-card__body p { color: var(--muted); font-size: var(--step--1); margin-top: 0.3rem; }
  .rub-card__count { display: inline-block; margin-top: 0.7rem; font-family: var(--font-mono); font-size: var(--step--2); color: var(--ember); letter-spacing: 0.05em; }
</style>
