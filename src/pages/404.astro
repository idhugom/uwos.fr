---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page introuvable" description="Cette page n'existe pas." noindex={true}>
  <section class="nf wrap">
    <div class="nf__code" aria-hidden="true">404</div>
    <h1>Cette page s'est volatilisée.</h1>
    <p>Le lien est peut-être cassé, ou la page a été déplacée. Pas de panique&nbsp;: tout le reste est juste là.</p>
    <div class="nf__actions">
      <a href="/" class="btn">Retour à l'accueil</a>
      <a href="/recherche/" class="btn btn--ghost">Rechercher un article</a>
    </div>
  </section>
</BaseLayout>

<style>
  .nf { min-height: 72vh; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; gap: 1.2rem; }
  .nf__code {
    font-family: var(--font-display); font-weight: 800; line-height: 0.8;
    font-size: clamp(6rem, 32vw, 20rem); letter-spacing: -0.05em;
    background: linear-gradient(180deg, var(--orange), transparent 130%);
    -webkit-background-clip: text; background-clip: text; color: transparent;
  }
  .nf h1 { font-size: var(--step-3); }
  .nf p { color: var(--muted); max-width: 44ch; }
  .nf__actions { display: flex; gap: 1rem; flex-wrap: wrap; justify-content: center; margin-top: 1rem; }
</style>
